# ─── Google Maps 3D Photorealistic Tiles ──────────────────────
# Required for 3D tiles; falls back to OpenStreetMap if omitted.
# Get yours: https://console.cloud.google.com/google/maps-apis
# Enable "Map Tiles API" → Create an API key → Restrict it (see README).
VITE_GOOGLE_API_KEY=

# ─── Cesium Ion (optional) ────────────────────────────────────
# Only needed if you want Cesium's own terrain/imagery services.
# Sign up free: https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=

# ─── CCTV Camera Sources ─────────────────────────────────────
# Windy webcam API (reserved, not yet active)
# Get yours: https://api.windy.com/
WINDY_API_KEY=

# Transport for NSW Open Data API
# Register: https://opendata.transport.nsw.gov.au/ → "My Applications" → Create App
NSW_TRANSPORT_API_KEY=

# AISStream.io — Real-time ship/vessel AIS tracking (WebSocket)
# Get yours: https://aisstream.io/ → Register → API Keys
AISSTREAM_API_KEY=


# ─── Google Maps 3D Photorealistic Tiles ──────────────────────
# Required for 3D tiles; falls back to OpenStreetMap if omitted.
# Get yours: https://console.cloud.google.com/google/maps-apis
# Enable: Map Tiles API → Create API key → restrict to your domain.
VITE_GOOGLE_API_KEY=AIzaSyC8-D5CowGRAEh60Lr22TRZjtUAfOFGP8A

# ─── Cesium Ion (optional) ────────────────────────────────────
# Only needed for Cesium's own terrain/imagery services.
# Sign up free: https://ion.cesium.com/tokens
